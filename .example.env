APP_NAME=MinecraftButlerAI
ENVIRONMENT=development
SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/minecraftbutlerai
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
TEST_DATABASE_ADMIN_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/postgres

# LLM / Agente
ANTHROPIC_API_KEY=your-anthropic-api-key

# LangSmith (observabilidad — opcional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=minecraftbutlerai
# Endpoint EU: https://eu.api.smith.langchain.com
LANGSMITH_ENDPOINT=
LANGCHAIN_TRACING_V2=false
# Poner a false en entornos con certificados SSL corporativos/proxy
SSL_VERIFY=true
