APP_NAME=MinecraftButlerAI
ENVIRONMENT=development
SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/minecraftbutlerai
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
TEST_DATABASE_ADMIN_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/postgres

# LLM / Agente
ANTHROPIC_API_KEY=your-anthropic-api-key

# LLM Factory — proveedor y modelos
# Proveedores disponibles: anthropic, openai
LLM_PROVIDER=anthropic
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
RESPONDER_MODEL=claude-sonnet-4-6
# API key de OpenAI (obligatoria si LLM_PROVIDER=openai o EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=

# Embeddings
# Proveedores disponibles: huggingface (gratis, descarga ~30s primera vez), openai
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Qdrant (vector store)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=minecraft_knowledge
QDRANT_API_KEY=
QDRANT_TOP_K=5
QDRANT_PREFETCH_LIMIT=20

# STT (Speech-to-Text con faster-whisper — local, sin API externa)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# Redis (memoria de conversación por sesión)
REDIS_URL=redis://localhost:6379
REDIS_SESSION_TTL_SECONDS=86400

# LangSmith (observabilidad — opcional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=minecraftbutlerai
# Endpoint EU: https://eu.api.smith.langchain.com
LANGSMITH_ENDPOINT=
LANGCHAIN_TRACING_V2=false
# Poner a false en entornos con certificados SSL corporativos/proxy
SSL_VERIFY=true
